# Coheus / Cohi Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Frontend Configuration
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# API Keys (get from respective providers)
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_COHERE_API_KEY=your-cohere-api-key

# Stripe (for subscription management)
VITE_STRIPE_PUBLIC_KEY=your-stripe-public-key

# Feature Flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_RAG=true
# Unified /api/chat/v1 client (data-chat, workbench, hub when migrated). Recommended true for local full-stack dev.
VITE_UNIFIED_CHAT=true

# HMDA DataBank (native integration)
VITE_HMDA_DATA_PREFIX=data/hmda/
HMDA_DATA_SOURCE=static
# HMDA_MLAR_DIR=data/hmda-mlar   # combined MLAR txt/zip for geography build
# HMDA_ANCHOR_YEAR=2025
# HMDA_FFIRC_CACHE_MS=21600000   # server FFIEC proxy cache (6h default)
# VITE_HMDA_FFIRC_LIVE=1         # merge live disposition into lender modals when API reachable
# VITE_HMDA_LENDERS_LIVE=1       # prod default: try FFIEC when static missing; static wins if present
# MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token
# VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token
