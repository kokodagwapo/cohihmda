# Copy to jira-import.env.local (gitignored) and fill in JIRA_API_TOKEN.
# Never commit jira-import.env.local.
#
# Create token: https://id.atlassian.com/manage-profile/security/api-tokens
#
JIRA_BASE_URL=https://teraverde.atlassian.net
JIRA_EMAIL=your-email@teraverde.com
JIRA_API_TOKEN=

# Optional: defaults to COHI
# JIRA_PROJECT_KEY=COHI
