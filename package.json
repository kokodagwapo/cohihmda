{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "init:management-db": "node scripts/create-management-db.js || bash scripts/create-management-db.sh",
    "init:management-schema": "node -e \"import('./server/src/config/managementDatabase.js').then(m => m.initManagementDatabase().then(() => { console.log('✅ Done'); process.exit(0); }).catch(e => { console.error('❌ Error:', e); process.exit(1); }));\"",
    "seed:management-db": "tsx scripts/seed-management-db.ts",
    "dev": "node scripts/launch-vite.mjs",
    "dev:backend": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "node scripts/launch-vite.mjs build",
    "build:dev": "node scripts/launch-vite.mjs build --mode development",
    "build:backend": "cd server && npm run build",
    "build:all": "npm run build:backend && npm run build",
    "lint": "eslint .",
    "preview": "node scripts/launch-vite.mjs preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:tracked-insights": "vitest run src/lib/trackedMetricPolarity.test.ts && cd server && npm run test:run -- src/services/insights/trackedPolarityInference.test.ts src/services/insights/trackedPolarityLlmResolution.test.ts src/services/trackedInsights/dashboardTrackedDerivation.test.ts src/services/research/tools.sqlPlaceholders.test.ts src/services/insights/trackedInsightParamResolution.test.ts src/services/dashboardInsights/dashboardInsightDetailHydrator.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:critical": "playwright test --grep @critical --project=chromium",
    "replay:unified-chat": "npx tsx server/scripts/replay/run-unified-chat-golden.ts",
    "replay:unified-chat:dry": "npx tsx server/scripts/replay/run-unified-chat-golden.ts --dry-run",
    "test:e2e:regression": "playwright test --grep @regression",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "e2e:check-env": "node scripts/e2e-check-env.mjs",
    "lint:qa:test-tags": "cd server && npx tsx scripts/qa/lib/lintTestTags.ts",
    "install:all": "npm install && cd server && npm install"
  },
