{
  "name": "coheus-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore ./logs --ignore ./node_modules src/index.ts",
    "prebuild": "node scripts/generate-version.js",
    "build": "tsc",
    "postbuild": "node scripts/generate-version.js",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrations/cli.ts up",
    "migrate:status": "tsx src/migrations/cli.ts status",
    "migrate:dry-run": "tsx src/migrations/cli.ts up --dry-run",
    "migrate:tenant": "tsx src/migrations/cli.ts tenant",
    "migrate:all": "tsx src/migrations/cli.ts all",
    "migrate:create": "tsx src/migrations/cli.ts create",
    "migrate:repair": "tsx scripts/repair-tenant-schemas.ts",
    "audit:pricing-schema": "tsx scripts/audit-tenant-pricing-schema.ts",
    "seed:super-admin": "tsx scripts/seed-super-admin.ts",
    "seed:local": "tsx scripts/seed-local-dev.ts",
    "news:refresh": "tsx scripts/refresh-news.ts",
    "init:local": "tsx scripts/init-local-database.ts",
    "create-admin": "node ../scripts/create-admin-user.js",
    "check-user": "tsx scripts/check-user-and-create-super-admin.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run src/test/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.980.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1020.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.980.0",
    "@aws-sdk/client-kms": "^3.980.0",
    "@aws-sdk/client-organizations": "^3.980.0",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/client-secrets-manager": "^3.980.0",
    "@aws-sdk/client-ses": "^3.980.0",
    "@sentry/node": "^10.32.1",
    "@types/uuid": "^10.0.0",
    "aws-jwt-verify": "^5.1.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.3",
    "pptxgenjs": "^4.0.1",
    "rss-parser": "^3.13.0",
    "stripe": "^17.7.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/csv-parse": "^1.1.12",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.16.5",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "fast-xml-parser": "5.3.4"
  }
}
