# Coheus / Cohi Backend Environment Configuration Template
# Copy this file to server/.env and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coheus
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================================
# User Credentials for Seeding (Development/Production)
# ============================================================================
# These are used by the seed script (npm run seed:users)
# SECURITY: Use strong passwords in production!

# Admin User (required)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-secure-password

# Standard User (optional, will be auto-generated if not provided)
USER_EMAIL=user@yourcompany.com
USER_PASSWORD=change-this-secure-password

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# AI Service API Keys
# ============================================================================
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
COHERE_API_KEY=your-cohere-api-key

# Podcast persistence / worker prefetch
PODCAST_AUDIO_BUCKET=
PODCAST_AUDIO_PREFIX=dev/audio
ALETHEIA_PREFETCH_ASYNC=false
ALETHEIA_PREFETCH_WORKER_ENABLED=false
ALETHEIA_PREFETCH_POLL_MS=60000
ALETHEIA_PREFETCH_MAX_JOBS_PER_TICK=2
ALETHEIA_NIGHTLY_PREFETCH_HOUR_UTC=2

# ============================================================================
# Vector Database (Pinecone)
# ============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=coheus-vectors

# ============================================================================
# Email Service (AWS SES)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
SES_FROM_EMAIL=noreply@yourcompany.com

# ============================================================================
# Stripe Configuration
# ============================================================================
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ============================================================================
# AWS Configuration (for deployments and provisioning)
# ============================================================================
AWS_KMS_KEY_ID=your-kms-key-id
AWS_CLOUDFORMATION_ROLE_ARN=your-cloudformation-role-arn

# ============================================================================
# AWS Cognito SSO Configuration
# ============================================================================
# Single Cognito User Pool handles all authentication (staff + tenants)
# Tenants can add their IdPs (Okta, Azure AD, etc.) as federated providers
#
# Get these from AWS Console > Cognito > User Pools > Your Pool > App Integration
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=your-client-secret-if-confidential
COGNITO_REGION=us-east-2
COGNITO_DOMAIN=your-app.auth.us-east-2.amazoncognito.com
# Must be exactly "true" (string). Local DB password auth is disabled by policy.
COGNITO_PASSWORD_AUTH=true

# ============================================================================
# Unified Cohi Chat (/api/chat/v1)
# ============================================================================
# Unset = enabled when NODE_ENV !== production. Set "false" to 404 the v1 routes.
UNIFIED_CHAT_ENABLED=true
# Set "false" to skip persisting turns to unified_chat_conversations from chat v1.
# UNIFIED_CHAT_PERSIST=true

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3001
# Comma-separated: first public (non-localhost) URL is used for email deep-links
FRONTEND_URL=http://localhost:8084,https://cohi.coheus1.com

# Fallout alert dev safety: comma-separated emails that receive redirected LO/manager
# emails in non-production (NODE_ENV != "production"). If unset, all LO/manager emails
# are blocked in dev — only manual test recipients go through.
FALLOUT_DEV_ALLOWED_EMAILS=your-email@example.com

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8084,http://localhost:5173

# ============================================================================
# Monitoring & Logging
# ============================================================================
# Sentry (optional)
SENTRY_DSN=your-sentry-dsn

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# LOS (Loan Origination System) Integration
# ============================================================================
LOS_API_URL=https://your-los-api.com
LOS_API_KEY=your-los-api-key
LOS_SYNC_ENABLED=false

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_VOICE=true
ENABLE_RAG=true
ENABLE_AWS_PROVISIONING=false
ENABLE_COST_TRACKING=true

# ============================================================================
# Fallout Prediction Configuration (RAG-based AI Loan Outcome Prediction)
# ============================================================================
# FRED API key for fetching mortgage market rates
FRED_API_KEY=58a508e93dc99372365ad789baa41e75

# AI model overrides — defaults are set in code but can be overridden here
COHI_CHAT_MODEL=gpt-5.4
INSIGHTS_MODEL=gpt-5.4
RESEARCH_MODEL=gpt-5.4
PREDICTION_MODEL=gpt-5.4-mini
RECOMMENDATION_MODEL=gpt-5.4
NEWS_MODEL=gpt-5.4-nano
PODCAST_MODEL=gpt-5.4

# Loan RAG Configuration
# Number of similar historical loans to retrieve per active loan (default 30)
LOAN_RAG_TOP_K=30

# Embedding model for canonical loan text (OpenAI)
LOAN_RAG_EMBEDDING_MODEL=openai/text-embedding-3-small

# Batch size for embedding API calls (default 50)
LOAN_RAG_EMBED_BATCH_SIZE=50
