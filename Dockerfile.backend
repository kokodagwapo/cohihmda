FROM node:20-alpine

WORKDIR /app/server

# Install dependencies for development and health check (wget for ECS)
RUN apk add --no-cache git wget

# Copy package files
COPY server/package*.json ./

# Install all dependencies (including dev dependencies for tsx)
RUN npm ci

# Copy server source
COPY server/ ./

# Expose port
EXPOSE 3001

# Default command
# For production: npm start
# For development: npm run dev
CMD ["npm", "run", "dev"]

