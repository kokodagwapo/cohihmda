# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coheus
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_MAX_CONNECTIONS=200
DB_POOL_SIZE=50
DB_SSL=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_KEY_PREFIX=coheus:tenant:
REDIS_TTL=3600
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Backend Configuration
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME_MIN_32_CHARACTERS_SECRET
FRONTEND_URL=http://localhost

# Multi-Tenant Configuration
TENANT_ISOLATION_ENABLED=true
TENANT_DEFAULT_ID=
MAX_TENANTS=1000
TENANT_RESOURCE_QUOTAS_ENABLED=true
TENANT_MAX_USERS=200
TENANT_MAX_LOANS=10000
TENANT_MAX_STORAGE_GB=100

# AI Services
OPENAI_API_KEY=
GEMINI_API_KEY=

# Frontend Configuration
VITE_API_URL=http://localhost:3001

# AWS Configuration (for EC2 deployment with managed services)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
RDS_ENDPOINT=
ELASTICACHE_ENDPOINT=

# Optional: Stripe, Sentry
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=
