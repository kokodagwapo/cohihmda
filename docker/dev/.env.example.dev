# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coheus
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=100
DB_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_KEY_PREFIX=coheus:tenant:
REDIS_TTL=3600

# Backend Configuration
NODE_ENV=development
PORT=3001
JWT_SECRET=dev-secret-min-32-characters-long-change-in-production
FRONTEND_URL=http://localhost:8080

# Multi-Tenant Configuration
TENANT_ISOLATION_ENABLED=true
TENANT_DEFAULT_ID=
MAX_TENANTS=100
TENANT_RESOURCE_QUOTAS_ENABLED=false

# AI Services
OPENAI_API_KEY=
GEMINI_API_KEY=

# Frontend Configuration
VITE_API_URL=http://localhost:3001
