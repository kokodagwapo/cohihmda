# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coheus
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=100
DB_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_KEY_PREFIX=coheus:tenant:
REDIS_TTL=3600

# Backend Configuration
NODE_ENV=development
PORT=3001
JWT_SECRET=dev-secret-min-32-characters-long-change-in-production
FRONTEND_URL=http://localhost:8080
DB_SSL=false

# Cognito (required for password auth). Skip MFA AWS preflight locally unless AWS creds are set.
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-2
COGNITO_DOMAIN=
COGNITO_PASSWORD_AUTH=true
COGNITO_SKIP_MFA_PREFLIGHT=true
LOCAL_DEV_PASSWORD_AUTH=true
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Multi-Tenant Configuration
TENANT_ISOLATION_ENABLED=true
TENANT_DEFAULT_ID=
MAX_TENANTS=100
TENANT_RESOURCE_QUOTAS_ENABLED=false

# AI Services
OPENAI_API_KEY=
GEMINI_API_KEY=

# Frontend Configuration
VITE_API_URL=http://localhost:3001
