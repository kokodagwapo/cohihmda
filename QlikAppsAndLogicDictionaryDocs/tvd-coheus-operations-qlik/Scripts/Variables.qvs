$(must_include=lib://QlikShare - SharedData/Include Files/Global.FederalHolidays.qss);

/*
1.REVENUE[wip]
2.Ad Hoc | Turn Times | Self Serv
3.Data Dictionary Addons
4.Ranges
5.Section Access

Look over field count
*/
LET vCurrentSetupFlag = Peek('Coheus Setup Flag',0,'$(vWriteTableName)');
If $(vCurrentSetupFlag) = 1 Then
	
    LET vXMLName = '30'&Text(Num(Replace('$(vClientID)','BE',''),00000000));
     
    EncInstances:
	Load distinct [Encompass Instance]
	Resident [$(vWriteTableName)];
	
    Let vNumofInstances = NoOfRows('EncInstances')-1;
	For vInstanceRecord = 0 To $(vNumofInstances)
		Let vFileName$(vInstanceRecord) = 'lib://QlikShare/CoheusConfigs/30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000))&'_cohuessetup.xml';
        Let vEncInstance$(vInstanceRecord) = '30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000));
	Next vInstanceRecord; Drop Table EncInstances;
    
	SET vFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_cohuessetup.xml';
    LET vConfigDictionary = 'Setup/DataDictionary/Field';
    LET vConfigAdHoc = 'Setup/CoheusConfig/AdHoc/Field';
    LET vConfigTurnTimes = 'Setup/CoheusConfig/TurnTimes/Field';
    SET vRevFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_profit_config.xml';
    LET vConfigProfitDictionary = 'ProfitabilityConfig/Dictionary/Field';
    LET vConfigProfitSwap = 'Setup/ProfitabilityConfig/FieldSwap/Field';
    LET vConfigSwap = 'Setup/CoheusConfig/FieldSwap/Field';
    LET vConfigRange = 'Setup/CoheusConfig/FieldRanges/Range';
    LET vLevelOneEntry = 'Setup/CoheusConfig/SectionAccess/LevelOne/Entry';
    LET vLevelOneAccess = 'Setup/CoheusConfig/SectionAccess/LevelOne';
    LET vLevelTwoEntry = 'Setup/CoheusConfig/SectionAccess/LevelTwo/Entry';
    LET vLevelTwoAccess = 'Setup/CoheusConfig/SectionAccess/LevelTwo';
    LET vLevelThreeEntry = 'Setup/CoheusConfig/SectionAccess/LevelThree/Entry';
    LET vLevelThreeAccess = 'Setup/CoheusConfig/SectionAccess/LevelThree';
    
    Drop Fields Revenue_Exec,Revenue_Sales,Revenue_Contribution,Revenue;
    Rename Field Revenue_Ops To Revenue;

ELSE
	LET vXMLName = '30'&Text(Num(Replace('$(vClientID)','BE',''),00000000));
    
    EncInstances:
	Load distinct [Encompass Instance]
	Resident [$(vWriteTableName)];

	Let vNumofInstances = NoOfRows('EncInstances')-1;
	For vInstanceRecord = 0 To $(vNumofInstances)
		Let vFileName$(vInstanceRecord) = 'lib://QlikShare/CoheusConfigs/30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000))&'_config.xml';
        Let vEncInstance$(vInstanceRecord) = '30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000));
	Next vInstanceRecord; Drop Table EncInstances;
    
	SET vFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_config.xml';
    LET vConfigDictionary = 'CoheusConfig/Dictionary/Field';
    LET vConfigAdHoc = 'CoheusConfig/AdHoc/Field';
    LET vConfigTurnTimes = 'CoheusConfig/TurnTimes/Field';
    SET vRevFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_profit_config.xml';
    LET vConfigProfitDictionary = 'ProfitabilityConfig/Dictionary/Field';
    LET vConfigProfitSwap = 'ProfitabilityConfig/FieldSwap/Field';
    LET vConfigSwap = 'CoheusConfig/FieldSwap/Field';
    LET vConfigRange = 'CoheusConfig/FieldRanges/Range';
    LET vLevelOneEntry = 'CoheusConfig/SectionAccess/LevelOne/Entry';
    LET vLevelOneAccess = 'CoheusConfig/SectionAccess/LevelOne';
    LET vLevelTwoEntry = 'CoheusConfig/SectionAccess/LevelTwo/Entry';
    LET vLevelTwoAccess = 'CoheusConfig/SectionAccess/LevelTwo';
    LET vLevelThreeEntry = 'CoheusConfig/SectionAccess/LevelThree/Entry';
    LET vLevelThreeAccess = 'CoheusConfig/SectionAccess/LevelThree';
End If;

