//Creates variable to present datetime of last qvd reload - USED FOR DEVELOPMENT/TESTING PURPOSES
// Let vQVDReloadTime = Num(QvdCreateTime('lib://QlikShare/QVD/LevelOne/Gold/L2/LevelOne.Coheus_Input.L2.qvd'));

//Creates variable to presen datetime of Last qvd reload - USES ODAG CONFIGURATION FILE
Let vQVDReloadTime = Num(QvdCreateTime('$(vMainFilePath)'));

Trace vQVDReloadTime: $(vQVDReloadTime);

//REVISE IN TEMPLATE APPS TO REFERENCE CONFIGURATION VARIABLES -Revised for Jan 2022 Release for Demo client.
DateList:
Load
	If('$(vClient)'='Demo',AddYears($(vQVDReloadTime),-5),If(Len(Trim(Min("Last Modified Date")))=0,AddYears(Today(),-5),Min("Last Modified Date"))) as MinDate,
    If('$(vClient)'='Demo',$(vQVDReloadTime),If(Len(Trim(Max("Last Modified Date")))=0,Today(),Max("Last Modified Date"))) as MaxDate
    
//Creates variable to present datetime of last qvd reload - USED FOR DEVELOPMENT/TESTING PURPOSES
// FROM [lib://QlikShare/QVD/LevelOne/Gold/L2/LevelOne.Coheus_Input.L2.qvd] (qvd);

//Creates variable to presen datetime of Last qvd reload - USES ODAG CONFIGURATION FILE
FROM [$(vMainFilePath)] (qvd);

Let vMinDate = Num(Peek('MinDate', 0, 'MinMax')); 
Let vMaxDate = Num(Peek('MaxDate', 0, 'MinMax'));

Let vCurrentDate = Num(Peek('MaxDate', 0, 'MinMax'));
Let vCurrentDateAsDate = Date(vCurrentDate, 'M/D/YYYY');

Trace vCurrentDate: $(vCurrentDate);
Trace vCurrentDateAsDate: $(vCurrentDateAsDate);
Trace vMaxDate: $(vMaxDate);

// LET vCurrentMTDWorkDays = If(NetWorkDays(MonthStart($(vMaxDate)), $(vMaxDate), $(vHolidays)) = 0, 1, NetWorkDays(MonthStart($(vMaxDate)), $(vMaxDate), $(vHolidays)));
// LET vCurrentYTDWorkDays = If(NetWorkDays(YearStart($(vMaxDate)), $(vMaxDate), $(vHolidays)) = 0, 1, NetWorkDays(YearStart($(vMaxDate)), $(vMaxDate), $(vHolidays)));

// Trace vCurrentMTDWorkDays: $(vCurrentMTDWorkDays);
// Trace vCurrentYTDWorkDays: $(vCurrentYTDWorkDays);
Let vCurrentYear = Year(vCurrentDate);
Let vLastYear = Year(vCurrentDate)-1;
Let vCurrentYearMonth = Year(vCurrentDate)&'-'&Month(vCurrentDate);
DROP TABLE DateList;

//REVISE IN TEMPLATE APPS TO REFERENCE CONFIGURATION VARIABLES - NOT USED IN GOLD 2020 APPS (FUTURE DEVELOPMENT)
InterestRateList:
Load
	Min([Interest Rate]) as MinInterestRate,
    Max([Interest Rate]) as MaxInterestRate,
    Floor(Max([Interest Rate])) as FloorMaxInterestRate,
    Count(DISTINCT [Interest Rate]) as InterestRateCount
Resident $(vWriteTableName);

Let vMinInterestRate = Num(Peek('MinInterestRate',0,'InterestRateList'),'#.##0');
Let vMaxInterestRate = Num(Peek('MaxInterestRate',0,'InterestRateList'),'#.##0');
Let vFloorMaxInterestRate = Num(Peek('FloorMaxInterestRate',0,'InterestRateList'),'#.##0');
Let InterestRateCount = Num(Peek('InterestRateCount',0,'InterestRateList'),'#,##0')&' Distinct Interest Rates';

Trace vMinInterestRate: $(vMinInterestRate);
Trace vMaxInterestRate: $(vMaxInterestRate);
Trace vFloorMaxInterestRate: $(vFloorMaxInterestRate);
Trace InterestRateCount: $(InterestRateCount);

DROP TABLE InterestRateList;

ClosingProj:
Load [Closing Projection Status],
	Min(RowNo) as RowSort
Resident [$(vWriteTableName)] 
Where Len(Trim([Closing Projection Status]))>0
Group By [Closing Projection Status];
Let vClosingProjColor=;

For i=0 to NoOfRows('ClosingProj')-1
Let vClosingProjColor='$(vClosingProjColor)'&'|'&Peek('Closing Projection Status',$(i),'ClosingProj');
Next i;
Drop Table ClosingProj;

// Snapshot Variables
Let vTrendGroupDim = 'Loan Purpose Group';
Let vTrendGroupDimLabel = Replace(vTrendGroupDim,'Group','');
Let vTrendGroupSet1 = 'Purchase';
Let vTrendGroupSet2 = 'Refinance';
Let vTrendDate = 'Funding';
Let vTrendDateLabel = if(vTrendDate='Closing','Closed','Funded');
Let vTrendShowRevenue = 0;
Let vTrendDateDetail = 'Credit Pull';
Let vTrendDetailShow = 0;
LET vSetDate = Year(vCurrentDateAsDate)&'-'&Month(vCurrentDateAsDate);
Let vSetDateCalc = '=MakeDate(SubField(vSetDate,'& CHR(39) &'-'& CHR(39) &',1),Num(Month(Date#(SubField(vSetDate,'& CHR(39) &'-'& CHR(39) &',-1),'& CHR(39) &'MMM'& CHR(39) &'))))';
Let vSnapshotDate1 = 'Funding';
Let vSnapshotDate2 = 'CTC';
Let vSnapshotDate2Label = if(vSnapshotDate2='UW Final Approval','Approved Loans','Clear to Close');
// Let vSnapshotDateToggle3 = 'Application';	//moved to SCRIPT | Additions to set  based on vVitalsChannel default to handle TPO clients. 
Let vSnapshotDate3Label = if(vSnapshotDate3='Application','Applications Taken','Registered');
Let vSnapshotRange = 'MTD';
Let vSnapshotRangeComparison = '=pick(match(vSnapshotRange,'& CHR(39) &'MTD'& CHR(39) &','& CHR(39) &'PreviousMonthFlag'& CHR(39) &','& CHR(39) &'YTDFlag'& CHR(39) &'),'& CHR(39) &'PreviousMTD'& CHR(39) &','& CHR(39) &'Previous2MonthFlag'& CHR(39) &','& CHR(39) &'PreviousYTDFlag'& CHR(39) &')';
Let vSnapshotShow = -1;
Let vSnapshotShowRevenue = 0;
Let vSnapshotSelectedYTD = '=vSetDate&' & CHR(39) &' YTD';
Let vSnapshotPreviousYTD = '=Year(AddMonths(vSetDateCalc,-12))&' & CHR(39) & '-' & CHR(39) & '&Month(AddMonths(vSetDateCalc,-12))&' & CHR(39) &' YTD';
Let vSnapshotSelectedMonth = '=if(vSetDate=vCurrentYearMonth,vSetDate&' & CHR(39) &' MTD'& CHR(39) &',vSetDate)';
Let vSnapshotPreviousMonth = '=if(vSetDate=vCurrentYearMonth,Year(AddMonths(vSetDateCalc,-1))&' & CHR(39) & '-' & CHR(39) & '&Month(AddMonths(vSetDateCalc,-1))&' & CHR(39) &' MTD'& CHR(39) &',Year(AddMonths(vSetDateCalc,-1))&' & CHR(39) & '-' & CHR(39) & '&Month(AddMonths(vSetDateCalc,-1)))';

// Lock Stratification Variables
Let vLockPTDays = 60;
Let vActiveLoansDim = 'Current Milestone';
SET vLock = 'No';

ChannelGrouping:
Load
	Channel as Channels,
    Sum([Loan Amount]) as ChannelLoanAmount
Resident $(vWriteTableName)
WHERE WildMatch(Channel,'99-Missing')=0 AND [Started Date] >= Date(MonthStart(AddMonths('$(vCurrentDateAsDate)',-12)))
Group By Channel;

// Vital Signs Variables
Let vVitalOrigDate = 'Funding';

DefaultChannel:
Load Channels as DefaultChannel
Resident ChannelGrouping
Order By ChannelLoanAmount desc;

// *** MAY 2022 ADDED Variable and List for Vital Signs ***
Let vVitalsChannel=Peek('DefaultChannel',0,'DefaultChannel');
Drop Tables ChannelGrouping,DefaultChannel;

// Set Active Aging "Start Date" based on vVitalsChannel default to handle TPO clients. If multi-channel will default to Application Date
// ----------------------------------------------------------------------------------------------------------------------------------------
LET vActiveAgingDate = if(WildMatch('$(vVitalsChannel)','*Whol*')>0,'Registration Date','Application Date');
LET vTPODimensionToggle = if(WildMatch('$(vVitalsChannel)','*Whol*')>0,'TPO','NonTPO');
LET vVitalTPODate = if(WildMatch('$(vVitalsChannel)','*Whol*')>0,'Registration','Application');