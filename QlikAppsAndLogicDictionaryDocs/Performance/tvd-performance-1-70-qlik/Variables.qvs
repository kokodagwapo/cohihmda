SET vCompanyScorecardDim = 'Branch';
SET vCompanyScorecardDateType = 'Application';
SET vCompanyScorecardActor = 'Loan Officer';
SET vCompanyScorecardChannel = '*';

SET vSize = Div(Log10(fabs($1)),3);
SET vAutoDollars = Dual(Num($1/Pow(10,3*$(vSize($1))),'$#,##0.00;($#,##0.00)')&Pick($(vSize($1)),'k','M','B','T'),$1);
SET vAuto = Dual(Num($1/Pow(10,3*$(vSize($1))),'#,##0;(#,##0)')&Pick($(vSize($1)),'k','M','B','T'),$1);
//variable to toggle second dimension on Closing Projections Summary pivot table
SET vCPDim='[Loan Purpose]';		

