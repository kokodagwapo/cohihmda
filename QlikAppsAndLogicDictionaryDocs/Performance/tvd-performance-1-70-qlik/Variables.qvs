/*
1.REVENUE[wip]
2.Ad Hoc | Turn Times | Self Serv
3.Data Dictionary Addons
4.Ranges
5.Section Access

Look over field count
*/
LET vCurrentSetupFlag = Peek('Coheus Setup Flag',0,'$(vWriteTableName)');
If $(vCurrentSetupFlag) = 1 Then
	
    LET vXMLName = '30'&Text(Num(Replace('$(vClientID)','BE',''),00000000));
     
    EncInstances:
	Load distinct [Encompass Instance]
	Resident [$(vWriteTableName)];
	
    Let vNumofInstances = NoOfRows('EncInstances')-1;
	For vInstanceRecord = 0 To $(vNumofInstances)
		Let vFileName$(vInstanceRecord) = 'lib://QlikShare/CoheusConfigs/30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000))&'_cohuessetup.xml';
        Let vEncInstance$(vInstanceRecord) = '30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000));
	Next vInstanceRecord; Drop Table EncInstances;
    
	SET vFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_cohuessetup.xml';
    SET vConfigDictionary = 'Setup/DataDictionary/Field';
    SET vConfigAdHoc = 'Setup/CoheusConfig/AdHoc/Field';
    SET vConfigTurnTimes = 'Setup/CoheusConfig/TurnTimes/Field';
    SET vRevFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_profit_config.xml';
    SET vConfigProfitDictionary = 'ProfitabilityConfig/Dictionary/Field';
    SET vConfigProfitSwap = 'Setup/ProfitabilityConfig/FieldSwap/Field';
    SET vConfigSwap = 'Setup/CoheusConfig/FieldSwap/Field';
    SET vConfigRange = 'Setup/CoheusConfig/FieldRanges/Range';
    SET vLevelOneEntry = 'Setup/CoheusConfig/SectionAccess/LevelOne/Entry';
    SET vLevelOneAccess = 'Setup/CoheusConfig/SectionAccess/LevelOne';
    SET vLevelTwoEntry = 'Setup/CoheusConfig/SectionAccess/LevelTwo/Entry';
    SET vLevelTwoAccess = 'Setup/CoheusConfig/SectionAccess/LevelTwo';
    SET vLevelThreeEntry = 'Setup/CoheusConfig/SectionAccess/LevelThree/Entry';
    SET vLevelThreeAccess = 'Setup/CoheusConfig/SectionAccess/LevelThree';
    
    Drop Fields Revenue_Exec,Revenue_Sales,Revenue_Contribution,Revenue;
    Rename Field Revenue_Ops To Revenue;

ELSE
	LET vXMLName = '30'&Text(Num(Replace('$(vClientID)','BE',''),00000000));
    
    EncInstances:
	Load distinct [Encompass Instance]
	Resident [$(vWriteTableName)];

	Let vNumofInstances = NoOfRows('EncInstances')-1;
	For vInstanceRecord = 0 To $(vNumofInstances)
		Let vFileName$(vInstanceRecord) = 'lib://QlikShare/CoheusConfigs/30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000))&'_config.xml';
        Let vEncInstance$(vInstanceRecord) = '30'&Text(Num(Replace(Peek('Encompass Instance',$(vInstanceRecord),'EncInstances'),'BE',''),00000000));
	Next vInstanceRecord; Drop Table EncInstances;
    
	SET vFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_config.xml';
    SET vConfigDictionary = 'CoheusConfig/Dictionary/Field';
    SET vConfigAdHoc = 'CoheusConfig/AdHoc/Field';
    SET vConfigTurnTimes = 'CoheusConfig/TurnTimes/Field';
    SET vRevFileName='lib://QlikShare/CoheusConfigs/$(vXMLName)_profit_config.xml';
    SET vConfigProfitDictionary = 'ProfitabilityConfig/Dictionary/Field';
    SET vConfigProfitSwap = 'ProfitabilityConfig/FieldSwap/Field';
    SET vConfigSwap = 'CoheusConfig/FieldSwap/Field';
    SET vConfigRange = 'CoheusConfig/FieldRanges/Range';
    SET vLevelOneEntry = 'CoheusConfig/SectionAccess/LevelOne/Entry';
    SET vLevelOneAccess = 'CoheusConfig/SectionAccess/LevelOne';
    SET vLevelTwoEntry = 'CoheusConfig/SectionAccess/LevelTwo/Entry';
    SET vLevelTwoAccess = 'CoheusConfig/SectionAccess/LevelTwo';
    SET vLevelThreeEntry = 'CoheusConfig/SectionAccess/LevelThree/Entry';
    SET vLevelThreeAccess = 'CoheusConfig/SectionAccess/LevelThree';
End If;





//Variables for App Information Tooltips & Coheus Logo
