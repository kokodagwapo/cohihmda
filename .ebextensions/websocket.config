option_settings:
  # Application Load Balancer Configuration for WebSocket Support
  # Note: ALB automatically supports WebSocket when it detects Upgrade header
  # These settings ensure optimal WebSocket performance
  
  aws:elbv2:loadbalancer:
    # Increase idle timeout for long-lived WebSocket connections (1 hour)
    # Default is 60 seconds, which is too short for WebSocket
    IdleTimeout: '3600'
    
  # Target Group Configuration
  aws:elasticbeanstalk:environment:process:default:
    # Health check path (should not interfere with WebSocket)
    HealthCheckPath: /health
    # Health check interval (seconds)
    HealthCheckInterval: 30
    # Health check timeout (seconds)
    HealthCheckTimeout: 5
    # Number of consecutive successful health checks before considering healthy
    HealthyThresholdCount: 3
    # Number of consecutive failed health checks before considering unhealthy
    UnhealthyThresholdCount: 5
    
  # Enable sticky sessions for WebSocket (required for ALB with multiple instances)
  # This ensures WebSocket connections stay with the same backend instance
  aws:elasticbeanstalk:environment:process:default:
    StickinessEnabled: 'true'
    StickinessLBCookieDuration: '86400'  # 24 hours
