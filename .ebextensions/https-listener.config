option_settings:
  # HTTPS Listener Configuration for Application Load Balancer
  # This enables secure WebSocket (wss://) connections from HTTPS pages
  # 
  # IMPORTANT: Before using this configuration:
  # 1. Request an SSL certificate in AWS Certificate Manager (ACM)
  # 2. Replace CERTIFICATE_ARN below with your actual certificate ARN
  # 3. Ensure the certificate is in the same region as your Elastic Beanstalk environment
  # 4. The certificate must be validated (DNS or email validation)
  #
  # To get your certificate ARN:
  # - Go to AWS Console → Certificate Manager (ACM)
  # - Find your certificate
  # - Copy the ARN (starts with arn:aws:acm:region:account:certificate/...)
  
  # HTTPS Listener on port 443
  aws:elbv2:listener:443:
    Protocol: HTTPS
    # Replace CERTIFICATE_ARN with your actual ACM certificate ARN
    # Example: arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012
    SSLCertificateArns: CERTIFICATE_ARN
    DefaultProcess: default
    ListenerEnabled: 'true'
    
  # Optional: Redirect HTTP to HTTPS
  # Uncomment the following to automatically redirect HTTP (port 80) to HTTPS (port 443)
  # aws:elbv2:listener:80:
  #   Protocol: HTTP
  #   DefaultProcess: default
  #   ListenerEnabled: 'true'
  #   Rules: 'default'
  # aws:elbv2:listenerrule:default:
  #   PathPatterns: '*'
  #   Process: default
  #   Priority: '1'
  #   Listener: 'default'
  #   Redirect: 'https://#{host}/#{path}?#{query}'
