                    <Card className="border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
                      <CardHeader>
                        <div className="flex items-center justify-between">
                          <div>
                            <CardTitle className="text-base font-light text-slate-900 dark:text-white tracking-tight">
                              Voice Usage & Costs
                            </CardTitle>
                            <CardDescription className="text-sm text-slate-600 dark:text-slate-400 font-light mt-1">
                              Track voice conversation minutes and costs
                            </CardDescription>
                          </div>
                          <Button
                            onClick={loadRagVoiceData}
                            variant="outline"
                            size="sm"
                            className="font-light"
                            disabled={ragVoiceLoading}
                          >
                            <RefreshCw className={`h-4 w-4 mr-2 ${ragVoiceLoading ? 'animate-spin' : ''}`} />
                            Refresh
                          </Button>
                        </div>
                      </CardHeader>
                      <CardContent>
                        {ragVoiceCosts.length === 0 ? (
                          <div className="text-center py-12">
                            <Mic className="h-12 w-12 text-slate-300 dark:text-slate-600 mx-auto mb-4" />
                            <p className="text-sm text-slate-500 dark:text-slate-400 font-light">
                              No voice usage data available
                            </p>
                            <p className="text-xs text-slate-400 dark:text-slate-500 font-light mt-2">
                              Voice conversation data will appear here after sessions are completed
                            </p>
                          </div>
                        ) : (
                          <div className="space-y-4">
                            {ragVoiceCosts.map((cost, index) => {
                              const totalMinutes = (cost.input_minutes || 0) + (cost.output_minutes || 0);
                              return (
                                <Card key={index} className="border-slate-200 dark:border-slate-700">
                                  <CardContent className="p-4">
                                    <div className="flex items-center justify-between mb-4">
                                      <div>
                                        <h4 className="text-sm font-medium text-slate-900 dark:text-white">
                                          {cost.service_name || 'Voice AI'}
                                        </h4>
                                        <p className="text-xs text-slate-500 dark:text-slate-400 font-light">
                                          {cost.service_provider || 'Unknown Provider'}
                                        </p>
                                      </div>
                                      <Badge variant="outline" className="font-light">
                                        {cost.total_sessions || 0} sessions
                                      </Badge>
                                    </div>
                                    <div className="grid grid-cols-3 gap-4">
                                      <div>
                                        <div className="flex items-center gap-2 mb-1">
                                          <Clock className="h-4 w-4 text-blue-500" />
                                          <span className="text-xs text-slate-500 dark:text-slate-400 font-light">Total Minutes</span>
                                        </div>
                                        <p className="text-lg font-light text-slate-900 dark:text-white">
                                          {totalMinutes.toFixed(2)}
                                        </p>
                                      </div>
                                      <div>
                                        <div className="flex items-center gap-2 mb-1">
                                          <Mic className="h-4 w-4 text-green-500" />
                                          <span className="text-xs text-slate-500 dark:text-slate-400 font-light">Input Minutes</span>
                                        </div>
                                        <p className="text-lg font-light text-slate-900 dark:text-white">
                                          {(cost.input_minutes || 0).toFixed(2)}
                                        </p>
                                      </div>
                                      <div>
                                        <div className="flex items-center gap-2 mb-1">
                                          <DollarSign className="h-4 w-4 text-orange-500" />
                                          <span className="text-xs text-slate-500 dark:text-slate-400 font-light">Total Cost</span>
                                        </div>
                                        <p className="text-lg font-light text-slate-900 dark:text-white">
                                          ${(cost.total_cost || 0).toFixed(4)}
                                        </p>
                                      </div>
                                    </div>
                                    <div className="mt-4 pt-4 border-t border-slate-200 dark:border-slate-700">
                                      <div className="grid grid-cols-2 gap-4 text-xs">
                                        <div>
                                          <span className="text-slate-500 dark:text-slate-400 font-light">Output Minutes:</span>
                                          <span className="ml-2 text-slate-900 dark:text-white font-light">
                                            {(cost.output_minutes || 0).toFixed(2)}
                                          </span>
                                        </div>
                                        <div>
                                          <span className="text-slate-500 dark:text-slate-400 font-light">Avg Cost/Min:</span>
                                          <span className="ml-2 text-slate-900 dark:text-white font-light">
                                            ${totalMinutes > 0 ? ((cost.total_cost || 0) / totalMinutes).toFixed(4) : '0.0000'}
                                          </span>
                                        </div>
                                      </div>
                                    </div>
                                  </CardContent>
                                </Card>
                              );
                            })}
                          </div>
                        )}
                      </CardContent>
                    </Card>
                  </>
                )}
              </motion.div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
};

export default Admin;
