type AdminSection = 'overview' | 'tenants' | 'users' | 'system' | 'security' | 'monitoring' | 'los' | 'synapse' | 'demo' | 'deployment' | 'stripe' | 'rag-voice' | 'soc2' | 'aws-hosting';

interface AdminStats {
  totalTenants: number;
  totalUsers: number;
  totalContacts: number;
  totalCalls: number;
  totalDocuments: number;
  totalLoans: number;
  deployments: number;
  losConnections: number;
  ragDocuments: number;
  isSuperAdmin: boolean;
  subscription: any | null;
  activeSubscriptions: number;
  costSummary: {
    total: number;
    voice: number;
    llm: number;
    embedding: number;
    aws: number;
  } | null;
  recent: {
    newUsers: number;
    newTenants: number;
    callsLast7d: number;
    loansLast7d: number;
  };
  loanStats: {
    total: number;
    active: number;
    closed: number;
    locked: number;
    total_volume: number;
    avg_loan_amount: number;
  } | null;
}

interface Tenant {
  id: string;
  name: string;
  created_at: string;
  updated_at: string;
}

interface User {
  id: string;
  email: string;
  created_at: string;
  email_confirmed_at: string | null;
  full_name: string | null;
  tenant_id: string | null;
  tenant_name: string | null;
  role?: string;
}

interface SystemInfo {
  database: {
    version: string;
    uptime: string;
  };
  server: {
    environment: string;
    port: string;
    nodeVersion: string;
  };
  features: {
    ragEnabled: boolean;
    costTrackingEnabled: boolean;
    hybridSyncEnabled: boolean;
  };
}

interface MonitoringData {
  recent: {
    newUsers: number;
    newTenants: number;
    callsLast24h: number;
  };
  database: {
    size: string;
  };
  dailyStats: Array<{
    date: string;
    count: number;
  }>;
}

interface SecurityInfo {
  authentication: {
    totalUsers: number;
    confirmedUsers: number;
    recentLogins: number;
    failedLogins?: number;
  };
  settings: {
    jwtExpiry: string;
    passwordMinLength: number;
    requireEmailConfirmation: boolean;
    encryptionEnabled?: boolean;
  };
  auditTrail?: {
    totalLogs: number;
    last24h: number;
    retentionDays: number;
  };
}

export const Admin = () => {
  const navigate = useNavigate();
  const { toast } = useToast();
  const { setTheme } = useTheme();
  const [loading, setLoading] = useState(false); // Changed: Don't block UI with loading
  const [overviewLoading, setOverviewLoading] = useState(true); // Separate loading state for Overview
  const [initialLoad, setInitialLoad] = useState(true); // Track initial load for preloader
  const [isAdmin, setIsAdmin] = useState(false);
  const [activeSection, setActiveSection] = useState<AdminSection>('overview');
  const [sectionDataLoaded, setSectionDataLoaded] = useState<Set<AdminSection>>(new Set()); // Track which sections have loaded
  
  // Force light theme for admin page - set as default
  useEffect(() => {
    // Set light theme as default for admin page
    setTheme('light');
    // Apply light theme to document root immediately and persist
    document.documentElement.classList.remove('dark');
    document.documentElement.classList.add('light');
    // Store in localStorage to persist across page reloads
    localStorage.setItem('vite-ui-theme', 'light');
  }, [setTheme]);
  const [tenants, setTenants] = useState<Tenant[]>([]);
  const [users, setUsers] = useState<User[]>([]);
  const [systemInfo, setSystemInfo] = useState<SystemInfo | null>(null);
  const [monitoringData, setMonitoringData] = useState<MonitoringData | null>(null);
  const [securityInfo, setSecurityInfo] = useState<SecurityInfo | null>(null);
  const [deployments, setDeployments] = useState<any[]>([]);
  const [deploymentsLoading, setDeploymentsLoading] = useState(false);
  const [syncEvents, setSyncEvents] = useState<any[]>([]);
  const [syncEventsLoading, setSyncEventsLoading] = useState(false);
  const [provisionModalOpen, setProvisionModalOpen] = useState(false);
  const [registerModalOpen, setRegisterModalOpen] = useState(false);
  const [syncModalOpen, setSyncModalOpen] = useState(false);
  const [provisionForm, setProvisionForm] = useState({
    instance_name: '',
    cloud_provider: 'aws' as 'aws' | 'azure' | 'gcp',
    cloud_region: '',
  });
  const [registerForm, setRegisterForm] = useState({
    instance_name: '',
    ip_address: '',
    hostname: '',
    version: '',
  });
  const [syncForm, setSyncForm] = useState({
    target_instance_id: '',
    sync_type: 'incremental' as 'full' | 'incremental' | 'realtime',
  });
  const [provisioning, setProvisioning] = useState(false);
  const [registering, setRegistering] = useState(false);
  const [syncing, setSyncing] = useState(false);
  const [subscriptions, setSubscriptions] = useState<any[]>([]);
  const [subscriptionPlans, setSubscriptionPlans] = useState<any[]>([]);
  const [stripeLoading, setStripeLoading] = useState(false);
  const [ragVoiceSettings, setRagVoiceSettings] = useState<any>(null);
  const [ragVoiceCosts, setRagVoiceCosts] = useState<any[]>([]);
  const [ragVoiceLoading, setRagVoiceLoading] = useState(false);
  const [apiKeysModalOpen, setApiKeysModalOpen] = useState(false);
  const [openaiKey, setOpenaiKey] = useState('');
  const [geminiKey, setGeminiKey] = useState('');
  const [savingKeys, setSavingKeys] = useState(false);
  const [selectedTenantId, setSelectedTenantId] = useState<string | null>(null); // For super admin tenant switching
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false); // Mobile sidebar menu state
  
  // User management states
  const [createUserDialogOpen, setCreateUserDialogOpen] = useState(false);
  const [editUserDialogOpen, setEditUserDialogOpen] = useState(false);
  const [deleteUserDialogOpen, setDeleteUserDialogOpen] = useState(false);
  const [selectedUser, setSelectedUser] = useState<User | null>(null);
  const [userForm, setUserForm] = useState({
    email: '',
    password: '',
    full_name: '',
    tenant_id: '',
    role: 'user' as 'super_admin' | 'tenant_admin' | 'loan_officer' | 'processor' | 'viewer' | 'user',
  });
  const [savingUser, setSavingUser] = useState(false);
  
  const [stats, setStats] = useState<AdminStats>({
    totalTenants: 0,
    totalUsers: 0,
    totalContacts: 0,
    totalCalls: 0,
    totalDocuments: 0,
    totalLoans: 0,
    deployments: 0,
    losConnections: 0,
    ragDocuments: 0,
    isSuperAdmin: false,
    subscription: null,
    activeSubscriptions: 0,
    costSummary: null,
    recent: {
      newUsers: 0,
      newTenants: 0,
      callsLast7d: 0,
      loansLast7d: 0,
    },
    loanStats: null,
  });
  const [searchQuery, setSearchQuery] = useState('');
  const [userSearchQuery, setUserSearchQuery] = useState('');
  const [losConnections, setLosConnections] = useState<any[]>([]);
  const [losTypes, setLosTypes] = useState<any>({});
  const [losLoading, setLosLoading] = useState(false);
  const [newConnectionOpen, setNewConnectionOpen] = useState(false);
  const [creatingConnection, setCreatingConnection] = useState(false);
  const [connectionForm, setConnectionForm] = useState({
    los_type: '',
    name: '',
    connection_method: 'api',
    api_base_url: '',
    api_client_id: '',
    api_client_secret: '',
    api_key: '',
    api_environment: 'sandbox',
    oauth_authorization_url: '',
    oauth_token_url: '',
    oauth_scopes: '',
    sync_enabled: true,
    sync_frequency: 'hourly',
    webhook_enabled: false,
    webhook_url: '',
    webhook_secret: '',
    csv_upload_schedule: 'manual',
    csv_upload_path: '',
    csv_field_mapping: '',
    db_host: '',
    db_port: '',
    db_name: '',
    db_user: '',
    db_password: '',
  });
  const [loadingLoans, setLoadingLoans] = useState(false);
  const [loans, setLoans] = useState<any[]>([]);
  const [loanPage, setLoanPage] = useState(1);
  const [loanTotal, setLoanTotal] = useState(0);
  const [editingLoan, setEditingLoan] = useState<any | null>(null);
  const [deletingLoanId, setDeletingLoanId] = useState<string | null>(null);
  const [csvFile, setCsvFile] = useState<File | null>(null);
  const [csvColumns, setCsvColumns] = useState<string[]>([]);
  const [fieldMapping, setFieldMapping] = useState<Record<string, string>>({});
  const [uploadingCsv, setUploadingCsv] = useState(false);
  const [vendorConnections, setVendorConnections] = useState<any[]>([]);
  const [vendorCatalog, setVendorCatalog] = useState<any>({});
  const [synapseLoading, setSynapseLoading] = useState(false);
  const [newVendorConnectionOpen, setNewVendorConnectionOpen] = useState(false);
  const [creatingVendorConnection, setCreatingVendorConnection] = useState(false);
  const [viewingLogsFor, setViewingLogsFor] = useState<string | null>(null);
  const [vendorSyncLogs, setVendorSyncLogs] = useState<any[]>([]);
  const [loadingLogs, setLoadingLogs] = useState(false);
  
  
  const [vendorConnectionForm, setVendorConnectionForm] = useState({
    vendor_name: '',
    vendor_category: 'accounting' as 'accounting' | 'capital_markets' | 'servicing',
    connection_type: 'lender_initiated' as 'vendor_initiated' | 'lender_initiated',
    vendor_api_key: '',
    vendor_api_endpoint: '',
    vendor_credentials: '',
    vendor_webhook_url: '',
    vendor_webhook_secret: '',
    data_mapping: '',
    sync_enabled: true,
    sync_frequency: 'hourly' as 'realtime' | 'hourly' | 'daily' | 'weekly',
  });

  useEffect(() => {
    checkAuth();
  }, []);

  // Load Overview stats immediately but non-blocking
  useEffect(() => {
    if (isAdmin) {
      // Start loading Overview stats immediately (non-blocking)
      loadData();
      // Hide preloader quickly after auth check
      setTimeout(() => setInitialLoad(false), 300);
    }
  }, [isAdmin]);

  // Lazy load section data only when section is clicked
  useEffect(() => {
    if (isAdmin && activeSection && activeSection !== 'overview') {
      // Load section data when user clicks on a menu item
      loadSectionDataLazy(activeSection);
    }
  }, [activeSection, isAdmin]);

  // Preload RAG & Voice Agentic data in background AFTER Overview loads (non-blocking)
  useEffect(() => {
    if (isAdmin && !overviewLoading) {
      // Wait for Overview to load, then preload RAG data in background
      const timer = setTimeout(() => {
        loadRagVoiceData(true).catch(() => {
          // Silently fail - data will load when section is clicked if preload fails
        });
      }, 1000); // Delay 1s after Overview loads
      return () => clearTimeout(timer);
    }
  }, [isAdmin, overviewLoading]);

  // Load RAG voice data when section becomes active
  useEffect(() => {
    if (isAdmin && activeSection === 'rag-voice' && !ragVoiceLoading && ragVoiceSettings === null) {
      loadRagVoiceData(false, selectedTenantId || null).catch((error) => {
        console.error('Error loading RAG voice data:', error);
      });
    }
  }, [activeSection, isAdmin, selectedTenantId]);

  const checkAuth = async () => {
    try {
      // Check if user has a token first
      const token = localStorage.getItem('auth_token');
      if (!token) {
        toast({
          title: 'Authentication Required',
          description: 'Please sign in to access the admin settings.',
          variant: 'destructive',
        });
        navigate('/login?returnTo=/admin');
        return;
      }

      // Try to get current user with a reasonable timeout
      const userData = await api.getCurrentUser();
      
      if (!userData.user) {
        toast({
          title: 'Authentication Required',
          description: 'Please sign in to access the admin settings.',
          variant: 'destructive',
        });
        navigate('/login?returnTo=/admin');
        return;
      }

      // Check if user has admin role
      const userRole = userData.user.role || 'user';
      const isAdminRole = userRole === 'super_admin' || userRole === 'tenant_admin';
      
      if (!isAdminRole) {
        toast({
          title: 'Access Denied',
          description: `This page requires admin privileges. Your role: ${userRole}. Please contact a system administrator.`,
          variant: 'destructive',
        });
        navigate('/');
        return;
      }

      setIsAdmin(true);
      // Load stats in background - don't block UI
      loadData().catch(console.error);
      setLoading(false);
      // Hide preloader quickly to show UI immediately
      setTimeout(() => setInitialLoad(false), 300);
    } catch (error: any) {
      console.error('Error checking authentication:', error);
      
      // If it's a timeout or connection error, check if token exists
      const token = localStorage.getItem('auth_token');
      const isTimeout = error.message?.includes('timeout') || error.message?.includes('timed out');
      const isConnectionError = error.message?.includes('connection') || error.message?.includes('Failed to fetch');
      
      if (isTimeout || isConnectionError) {
        // If we have a token but connection failed, show a warning but don't redirect immediately
        if (token) {
          toast({
            title: 'Connection Issue',
            description: 'Unable to verify authentication. Please check your connection and try again.',
            variant: 'destructive',
          });
          // Still allow access if token exists (might be a temporary network issue)
          setIsAdmin(true);
          // Don't block UI - load data in background
          loadData().catch(console.error);
          setLoading(false);
          setTimeout(() => setInitialLoad(false), 300); // Faster preloader dismissal
          return;
        }
      }
      
      // No token or authentication error - redirect to login
      toast({
        title: 'Authentication Required',
        description: 'Please sign in to access the admin settings.',
        variant: 'destructive',
      });
      navigate('/login?returnTo=/admin');
    }
  };

  // Load Overview stats in background (non-blocking)
  const loadData = async () => {
    try {
      setOverviewLoading(true);
      // Use requestIdleCallback or setTimeout to defer heavy API call
      const statsData = await api.request<AdminStats>('/api/admin/stats');
      setStats(statsData);
      setOverviewLoading(false);
    } catch (error: any) {
      console.error('Error loading admin data:', error);
      setOverviewLoading(false);
      
      // Handle 403 Forbidden specifically
      if (error.message?.includes('Forbidden') || error.message?.includes('403')) {
        toast({
          title: 'Access Denied',
          description: 'You do not have permission to access admin data. Please contact a system administrator.',
          variant: 'destructive',
        });
        // Optionally redirect if user doesn't have admin role
        const userData = await api.getCurrentUser().catch(() => ({ user: null }));
        const userRole = userData.user?.role || 'user';
        if (userRole !== 'super_admin' && userRole !== 'tenant_admin') {
          navigate('/');
        }
        return;
      }
      
      // Don't show toast on initial load - silent fail, will retry when user interacts
      if (activeSection === 'overview') {
        toast({
          title: 'Error',
          description: error.message || 'Failed to load admin data.',
          variant: 'destructive',
        });
      }
    }
  };

  // Lazy load section data only when section is clicked
  const loadSectionDataLazy = async (section: AdminSection) => {
    // Skip if already loaded
    if (sectionDataLoaded.has(section) && section !== 'overview') {
      return;
    }

    try {
      switch (section) {
        case 'tenants':
          if (!sectionDataLoaded.has('tenants')) {
            const tenantsData = await api.request<{ tenants: Tenant[] }>('/api/admin/tenants');
            setTenants(tenantsData.tenants || []);
            setSectionDataLoaded(prev => new Set(prev).add('tenants'));
          }
          break;
        case 'users':
          if (!sectionDataLoaded.has('users')) {
            // Load users and tenants in parallel for better performance
            const [usersData, tenantsData] = await Promise.all([
              api.request<{ users: User[] }>('/api/admin/users'),
              tenants.length === 0 
                ? api.request<{ tenants: Tenant[] }>('/api/admin/tenants')
                : Promise.resolve({ tenants: tenants })
            ]);
            setUsers(usersData.users || []);
            // Set tenants if we loaded them
            if (tenants.length === 0 && tenantsData.tenants) {
              setTenants(tenantsData.tenants || []);
            }
            setSectionDataLoaded(prev => new Set(prev).add('users'));
          }
          break;
        case 'system':
          if (!sectionDataLoaded.has('system')) {
            try {
              const systemData = await api.request<SystemInfo>('/api/admin/system');
              setSystemInfo(systemData);
            } catch (error: any) {
              console.error('Error loading system info:', error);
              setSystemInfo({
                database: { version: 'Unknown', uptime: 'Unknown' },
                server: { environment: import.meta.env.MODE || 'development', port: '3001', nodeVersion: 'Unknown' },
                features: { ragEnabled: false, costTrackingEnabled: false, hybridSyncEnabled: false },
              });
            }
            if (loans.length === 0) {
              fetchLoans();
            }
            setSectionDataLoaded(prev => new Set(prev).add('system'));
          }
          break;
        case 'monitoring':
          if (!sectionDataLoaded.has('monitoring')) {
            const monitoringData = await api.request<MonitoringData>('/api/admin/monitoring');
            setMonitoringData(monitoringData);
            setSectionDataLoaded(prev => new Set(prev).add('monitoring'));
          }
          break;
        case 'security':
          if (!sectionDataLoaded.has('security')) {
            const securityData = await api.request<SecurityInfo>('/api/admin/security');
            setSecurityInfo(securityData);
            setSectionDataLoaded(prev => new Set(prev).add('security'));
          }
          break;
        case 'los':
          if (!sectionDataLoaded.has('los')) {
            await loadLosData();
            setSectionDataLoaded(prev => new Set(prev).add('los'));
          }
          break;
        case 'synapse':
          if (!sectionDataLoaded.has('synapse')) {
            await loadSynapseData();
            setSectionDataLoaded(prev => new Set(prev).add('synapse'));
          }
          break;
        case 'deployment':
          if (!sectionDataLoaded.has('deployment')) {
            await loadDeployments();
            await loadSyncEvents();
            setSectionDataLoaded(prev => new Set(prev).add('deployment'));
          }
          break;
        case 'stripe':
          if (!sectionDataLoaded.has('stripe')) {
            await loadStripeData();
            setSectionDataLoaded(prev => new Set(prev).add('stripe'));
          }
          break;
        case 'rag-voice':
          // RAG voice has its own loading state, handled separately
          if (!sectionDataLoaded.has('rag-voice') && !ragVoiceLoading) {
            await loadRagVoiceData(false, selectedTenantId || null);
            setSectionDataLoaded(prev => new Set(prev).add('rag-voice'));
          }
          break;
      }
    } catch (error: any) {
      console.error(`Error loading ${section} data:`, error);
      toast({
        title: 'Error',
        description: error.message || `Failed to load ${section} data.`,
        variant: 'destructive',
      });
    }
  };

  // Legacy function - kept for compatibility, now uses lazy loading
  const loadSectionData = async () => {
    await loadSectionDataLazy(activeSection);
  };

  // User Management Functions
  const handleCreateUser = async (userData: any) => {
    try {
      await api.request('/api/admin/users', {
        method: 'POST',
        body: JSON.stringify(userData),
      });
      
      toast({
        title: 'Success',
        description: 'User created successfully',
      });
      
      // Reload users
      const usersData = await api.request<{ users: User[] }>('/api/admin/users');
      setUsers(usersData.users || []);
    } catch (error: any) {
      console.error('Error creating user:', error);
      toast({
        title: 'Error',
        description: error.message || 'Failed to create user',
        variant: 'destructive',
      });
      throw error; // Re-throw so the component can handle it
    }
  };

  const handleEditUser = async (userId: string, userData: any) => {
    try {
      await api.request(`/api/admin/users/${userId}`, {
        method: 'PUT',
        body: JSON.stringify(userData),
      });
      
      toast({
        title: 'Success',
        description: 'User updated successfully',
      });
      
      // Reload users
      const usersData = await api.request<{ users: User[] }>('/api/admin/users');
      setUsers(usersData.users || []);
    } catch (error: any) {
      console.error('Error updating user:', error);
      toast({
        title: 'Error',
        description: error.message || 'Failed to update user',
        variant: 'destructive',
      });
      throw error; // Re-throw so the component can handle it
    }
  };

  const handleDeleteUser = async (userId: string) => {
    await api.request(`/api/admin/users/${userId}`, {
      method: 'DELETE',
    });
    
    toast({
      title: 'Success',
      description: 'User deleted successfully',
    });
    
    // Reload users
    const usersData = await api.request<{ users: User[] }>('/api/admin/users');
    setUsers(usersData.users || []);
  };

  const adminSections = [
    { id: 'overview' as AdminSection, label: 'Overview', icon: BarChart3, description: 'System statistics and metrics', color: 'text-blue-300 dark:text-blue-400/70' },
    { id: 'tenants' as AdminSection, label: 'Tenants', icon: Building2, description: 'Manage tenant accounts', color: 'text-emerald-300 dark:text-emerald-400/70' },
    { id: 'users' as AdminSection, label: 'Users', icon: Users, description: 'User management', color: 'text-purple-300 dark:text-purple-400/70' },
    { id: 'los' as AdminSection, label: 'LOS Settings', icon: Link2, description: 'Loan Origination System connections', color: 'text-orange-300 dark:text-orange-400/70' },
