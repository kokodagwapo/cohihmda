  const handleCreateConnection = async () => {
    // Validation
    if (!connectionForm.los_type || !connectionForm.name) {
      toast({
        title: 'Validation Error',
        description: 'Please fill in all required fields (LOS Type and Name).',
        variant: 'destructive',
      });
      return;
    }

    // Validate API method fields
    if (connectionForm.connection_method === 'api') {
      const losConfig = losTypes[connectionForm.los_type];
      if (losConfig?.authType === 'oauth2') {
        if (!connectionForm.api_client_id || !connectionForm.api_client_secret) {
          toast({
            title: 'Validation Error',
            description: `${losConfig.name} uses OAuth2 authentication. Client ID and Client Secret are required.`,
            variant: 'destructive',
          });
          return;
        }
        if (!connectionForm.oauth_authorization_url || !connectionForm.oauth_token_url) {
          toast({
            title: 'Validation Error',
            description: 'OAuth2 requires Authorization URL and Token URL.',
            variant: 'destructive',
          });
          return;
        }
      } else if (losConfig?.authType === 'api_key') {
        if (!connectionForm.api_key) {
          toast({
            title: 'Validation Error',
            description: `${losConfig.name} requires an API Key for authentication.`,
            variant: 'destructive',
          });
          return;
        }
      } else if (!losConfig) {
        // Generic/Custom LOS - at least one auth method must be provided
        if (!connectionForm.api_key && !connectionForm.api_client_id) {
          toast({
            title: 'Validation Error',
            description: 'Please provide either an API Key or OAuth credentials for authentication.',
            variant: 'destructive',
          });
          return;
        }
      }
      
      // Validate API Base URL is provided
      if (!connectionForm.api_base_url) {
        toast({
          title: 'Validation Error',
          description: 'API Base URL is required for API connections.',
          variant: 'destructive',
        });
        return;
      }
    }

    // Validate database method fields
    if (connectionForm.connection_method === 'database') {
      if (!connectionForm.db_host || !connectionForm.db_name || !connectionForm.db_user) {
        toast({
          title: 'Validation Error',
          description: 'Database connections require Host, Database Name, and User.',
          variant: 'destructive',
        });
        return;
      }
    }

    setCreatingConnection(true);
    try {
      const payload: any = {
        los_type: connectionForm.los_type,
        name: connectionForm.name.trim(),
        connection_method: connectionForm.connection_method,
        sync_enabled: connectionForm.sync_enabled,
        sync_frequency: connectionForm.sync_frequency,
        webhook_enabled: connectionForm.webhook_enabled,
      };

      // Add API fields if connection method is API
      if (connectionForm.connection_method === 'api') {
        payload.api_environment = connectionForm.api_environment;
        if (connectionForm.api_base_url) payload.api_base_url = connectionForm.api_base_url.trim();
        if (connectionForm.api_client_id) payload.api_client_id = connectionForm.api_client_id.trim();
        if (connectionForm.api_client_secret) payload.api_client_secret = connectionForm.api_client_secret.trim();
        if (connectionForm.api_key) payload.api_key = connectionForm.api_key.trim();
        if (connectionForm.oauth_authorization_url) payload.oauth_authorization_url = connectionForm.oauth_authorization_url.trim();
        if (connectionForm.oauth_token_url) payload.oauth_token_url = connectionForm.oauth_token_url.trim();
        if (connectionForm.oauth_scopes) payload.oauth_scopes = connectionForm.oauth_scopes.trim();
      }

      // Add CSV upload fields if method is CSV
      if (connectionForm.connection_method === 'csv_upload') {
        payload.csv_upload_schedule = connectionForm.csv_upload_schedule;
        if (connectionForm.csv_upload_path) {
          payload.csv_upload_path = connectionForm.csv_upload_path.trim();
        }
        if (connectionForm.csv_field_mapping) {
          try {
            // Validate JSON if provided
            const mapping = JSON.parse(connectionForm.csv_field_mapping);
            payload.csv_field_mapping = mapping;
          } catch (e) {
            toast({
              title: 'Invalid JSON',
              description: 'CSV Field Mapping must be valid JSON. Please check your input.',
              variant: 'destructive',
            });
            setCreatingConnection(false);
            return;
          }
        }
      }

      // Add webhook fields if enabled
      if (connectionForm.webhook_enabled) {
        if (connectionForm.webhook_url) {
          payload.webhook_url = connectionForm.webhook_url.trim();
        }
        if (connectionForm.webhook_secret) {
          payload.webhook_secret = connectionForm.webhook_secret.trim();
        }
      }

      // Add database fields if connection method is database
      if (connectionForm.connection_method === 'database') {
        if (connectionForm.db_host) payload.db_host = connectionForm.db_host.trim();
        if (connectionForm.db_port) {
          const port = parseInt(connectionForm.db_port);
          if (!isNaN(port)) payload.db_port = port;
        }
        if (connectionForm.db_name) payload.db_name = connectionForm.db_name.trim();
        if (connectionForm.db_user) payload.db_user = connectionForm.db_user.trim();
        if (connectionForm.db_password) payload.db_password = connectionForm.db_password;
      }

      const response = await api.request<{ connection: any }>('/api/los/connections', {
        method: 'POST',
        body: JSON.stringify(payload),
      });

      // If CSV file was uploaded, process it now
      if (csvFile && connectionForm.connection_method === 'csv_upload' && response.connection?.id) {
        try {
          // Get the file path from the upload (stored in state)
          const csvFilePath = (csvFile as any).serverPath || csvFile.name;
          
          // Process the uploaded CSV file with field mapping
          const processResponse = await api.request('/api/los/csv/process', {
            method: 'POST',
            body: JSON.stringify({
              filePath: csvFilePath,
              connectionId: response.connection.id,
              fieldMapping: fieldMapping,
            }),
          });

          toast({
            title: 'CSV Processed',
            description: `Processed ${processResponse.records_processed || 0} records from ${csvFile.name}.`,
          });
        } catch (error: any) {
          console.error('Error processing CSV:', error);
          // Don't fail the connection creation if CSV processing fails
          toast({
            title: 'CSV Processing Warning',
            description: 'Connection created but CSV processing failed. You can retry from the connection details.',
            variant: 'destructive',
          });
        }
      }

      toast({
        title: 'Connection Created',
        description: `Successfully created ${connectionForm.name} connection. ${connectionForm.sync_enabled ? 'Sync is enabled.' : 'Enable sync to start automation.'}`,
      });

      // Reset form
      setConnectionForm({
        los_type: '',
        name: '',
        connection_method: 'api',
        api_base_url: '',
        api_client_id: '',
        api_client_secret: '',
        api_key: '',
        api_environment: 'sandbox',
        oauth_authorization_url: '',
        oauth_token_url: '',
        oauth_scopes: '',
        sync_enabled: true,
        sync_frequency: 'hourly',
        webhook_enabled: false,
        webhook_url: '',
        csv_upload_schedule: 'manual',
        csv_upload_path: '',
        csv_field_mapping: '',
        webhook_secret: '',
      });
      
      // Reset CSV-related state
      setCsvFile(null);
      setCsvColumns([]);
      setFieldMapping({});

      setNewConnectionOpen(false);
      await loadLosData();

      // If CSV file was uploaded, process it now
      if (csvFile && connectionForm.connection_method === 'csv_upload') {
        try {
          // Get the uploaded file path from the upload response
          // For now, we'll trigger processing via the sync endpoint
          const connectionId = (response as any).connection?.id;
