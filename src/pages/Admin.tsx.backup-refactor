                connectionId,
                fieldMapping: fieldMapping,
              }),
            });

            toast({
              title: 'CSV Processed',
              description: `Processed ${processResponse.records_processed || 0} records from CSV file.`,
            });
          }
        } catch (error: any) {
          console.error('Error processing CSV:', error);
          // Don't fail the connection creation if CSV processing fails
        }
      }

      // Reset CSV-related state
      setCsvFile(null);
      setCsvColumns([]);
      setFieldMapping({});

      setNewConnectionOpen(false);
      await loadLosData();
    } catch (error: any) {
      console.error('Error creating connection:', error);
      toast({
        title: 'Creation Failed',
        description: error.message || error.error || 'Failed to create LOS connection. Please check your inputs.',
        variant: 'destructive',
