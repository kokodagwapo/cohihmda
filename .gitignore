*.sw?

# Environment variables
.env
.env.local
.env.production
.env.development
.env.test
server/.env
server/.env.local
server/.env.production
*.env

# Allow .env.example files (these are templates, not actual secrets)
!.env.example
!server/.env.example

# Credentials generated by seed script (development only)
