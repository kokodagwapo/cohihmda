# Dependencies
node_modules
dist
dist-ssr
*.local

# Generated version file
server/src/version.json
server/dist/version.json

# Build outputs (docs is used for GitHub Pages, but exclude build artifacts)
!docs
docs/assets/*.js.map
docs/assets/*.css.map
# Ignore hashed build artifacts in docs/assets
docs/assets/index-*.js
docs/assets/index-*.css
docs/assets/*.es-*.js

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
